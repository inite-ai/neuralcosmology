# Docker Hub credentials
DOCKERHUB_USERNAME=your-dockerhub-username

# Let's Encrypt email
ACME_EMAIL=your-email@example.com

# Site URL (used during build)
NEXT_PUBLIC_SITE_URL=https://neuralcosmology.com

# Mailgun SMTP for contact form (/api/contact)
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=2525
MAILGUN_SMTP_USERNAME=postmaster@your-domain.mailgun.org
MAILGUN_SMTP_PASSWORD=your-mailgun-smtp-password
MAILGUN_FROM_EMAIL=info@neuralcosmology.com
CONTACT_EMAIL=info@neuralcosmology.com

