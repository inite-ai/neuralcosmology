set -e

echo "🔍 Pre-commit checks..."

# package.json / package-lock.json sync
if [ -f package.json ] && [ -f package-lock.json ]; then
    if ! npm ci --dry-run > /dev/null 2>&1; then
        echo "❌ package.json and package-lock.json are out of sync"
        echo "💡 Run 'npm install' to fix"
        exit 1
    fi
fi

# Linter (non-blocking)
if [ -f package.json ] && grep -q '"lint"' package.json; then
    if npm run lint -- --max-warnings=0 > /dev/null 2>&1; then
        echo "✅ Lint passed"
    else
        echo "⚠️  Lint found issues (non-blocking)"
    fi
fi

echo "✅ Pre-commit ok"
