current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

if [ "$current_branch" = "main" ] || [ "$current_branch" = "master" ]; then
    echo "🔨 Build check before push to $current_branch…"

    run_with_timeout() {
        local timeout=$1
        shift
        if command -v gtimeout >/dev/null 2>&1; then
            gtimeout "$timeout" "$@"
        elif command -v timeout >/dev/null 2>&1; then
            timeout "$timeout" "$@"
        else
            "$@" &
            local pid=$!
            ( sleep "$timeout" && kill -TERM $pid 2>/dev/null ) &
            local killer=$!
            if wait $pid 2>/dev/null; then
                kill -TERM $killer 2>/dev/null
                wait $killer 2>/dev/null
                return 0
            else
                kill -TERM $killer 2>/dev/null
                wait $killer 2>/dev/null
                return 124
            fi
        fi
    }

    if run_with_timeout 180 npm run build > /tmp/neurocosmology-build.log 2>&1; then
        echo "✅ Build ok"
    else
        exit_code=$?
        if [ $exit_code -eq 124 ]; then
            echo "⚠️  Build timeout (180s) — пропускаю проверку"
            exit 0
        fi
        echo "❌ Build failed"
        tail -40 /tmp/neurocosmology-build.log
        echo ""
        echo "💡 Полный лог: /tmp/neurocosmology-build.log"
        exit 1
    fi
else
    echo "ℹ️  Not on main — skipping build check"
fi

echo "✅ Pre-push ok"
